@startuml Activity Diagram
!include _dark-theme.puml
title Remote Worker Flow (ExecutionService, in a pool runspace)

start
:Receive HostName + JobType + Options;
note right: Runs on a RunspaceManager pool\nthread, never the WPF dispatcher.

:Assert host reachable;
note right
  RemoteJobService.AssertHostReachable()
  IsOnline() -> ResolveHost() -> IsRpcAvailable(135)
end note

if (Reachable?) then (no)
    :Log error + return Failure;
    stop
else (yes)
endif

switch (JobType?)
case (Resolve / WarmRunspace)
    :Resolve via active DC + reverse-DNS verify;
    note right: HostResolver caches the IP;\nWarmRunspace is a no-op that\njust pre-loads the module graph.
case (Scan / UpdateScan)
    :Run DCU-CLI scan via PsExec (SYSTEM);
case (UpdateApply)
    :Run DCU-CLI applyUpdates via PsExec;
    :Flag RebootRequired from exit code;
case (Inventory)
    :Run inventory probe (CIM) via PsExec;
case (DiskScan)
    :Deploy + run wiztree64.exe (MFT scan);
endswitch

:Copy remote artifacts back;
note right
  From the UNC admin share and C:/temp/DONUT
  into %LOCALAPPDATA%/DONUT/logs and /reports
end note

if (Artifacts copied?) then (yes)
    :Parse report (XML / JSON / CSV);
    :Return Success + result;
else (no)
    :Log error + return Failure;
endif

stop
@enduml
