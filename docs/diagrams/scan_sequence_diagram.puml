@startuml Scan Sequence Diagram
title Scan a Machine (async, non-blocking)

actor User
participant "HomeView" as View
participant "HomePresenter" as Presenter
participant "ScanService" as Scan
participant "AsyncJob" as Job
participant "RunspacePool" as Pool
participant "ExecutionService" as Exec

User -> View: Click row "Run" (mode = Scan)
View -> Presenter: RunHost("PC-01")
activate Presenter
Presenter -> Presenter: StartProcess("PC-01")

alt Scan < 24h old and report cached
    Presenter -> Presenter: RecentScanIsFresh() = true
    note right of Presenter: ScanCacheDecision.IsFresh()\nToast "results are current" — no job queued.
else Needs a fresh scan
    Presenter -> Scan: PrepareScan("PC-01")
    activate Scan
    Scan -> Scan: BuildWorkerArgs("PC-01", "Scan", {})
    Scan --> Presenter: worker args (no network on UI thread)
    deactivate Scan

    Presenter -> Job: new AsyncJob("PC-01", Scan)
    Presenter -> Pool: GetPool()
    Presenter -> Job: Start(scriptPath, args)
    Presenter -> Presenter: ActiveJobs.Add(job)
end
deactivate Presenter

== DispatcherTimer tick: PumpJobs() ==

loop while job running
    Presenter -> Job: Poll()
    activate Job
    Job -> Exec: (pool thread) AssertHostReachable + RunScanPhase
    activate Exec
    Exec -> Exec: DCU-CLI scan via PsExec
    Exec -> Exec: CopyRemoteArtifacts()
    Exec --> Job: scan result + report path
    deactivate Exec
    Job --> Presenter: Status (Running / Completed)
    deactivate Job
    Presenter -> Presenter: OnJobPolled() -> stream logs + % to card
end

Presenter -> Presenter: OnJobCompleted() -> SettleHost(job)
Presenter -> Presenter: Store.Upsert(host, status, updateCount)
Presenter -> View: card -> Completed + update count
@enduml
