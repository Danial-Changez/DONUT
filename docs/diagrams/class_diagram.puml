@startuml Class Diagram
title DONUT — Class Structure
skinparam classAttributeIconSize 0

' Each layer carries its own muted tint so the four packages read at a glance:
'   Models = blue · Core = green · Services = violet · UI = amber
package "Donut.Models" #15233B {
    class AppConfig {
        +SourceRoot: string
        +LogsPath: string
        +ReportsPath: string
        +Settings: Hashtable
        +{static} Defaults: Hashtable
        --
        +GetSetting(key, default): object
        +SetSetting(key, value): void
        +GetActiveCommand(): string
        +GetCommandArgs(command): Hashtable
        +GetThrottleLimit(): int
        +BuildDcuArgs(command, overrides): string
        -MergeWithDefaults(userSettings): Hashtable
    }

    class DeviceContext {
        +HostName: string
        +IPAddress: string
        +IsOnline: bool
        +StatusMessage: string
    }

    enum JobStatus {
        Created
        Running
        Completed
        Failed
    }

    enum JobKind {
        Scan
        UpdateScan
        UpdateApply
        Inventory
        DiskScan
        Resolve
    }

    enum FleetState {
        Queued
        Scanning
        Updating
        Completed
        RebootRequired
        Failed
    }

    class FleetStatus {
        +State: FleetState
        +Label: string
        +ColorKey: string
        +IsBusy: bool
        +{static} FromJob(jobType, status, rebootRequired): FleetStatus
    }

    class DcuProgress {
        +{static} ParsePercent(line): double
    }

    class ScanCacheDecision {
        +{static} IsFresh(lastJobType, lastSeen, now, ttl, reportExists): bool
    }

    class MachineInventory {
        +Model: string
        +ServiceTag: string
        +BiosVersion: string
        +HasBattery: bool
        +DesignCapacity: long
        +FullChargeCapacity: long
        +ChargePercent: int
        +FreeSpaceBytes: long
        +TotalSpaceBytes: long
        +LastBootTime: string
        +{static} FromHashtable(h): MachineInventory
        +ToHashtable(): Hashtable
    }

    class InventoryFormat {
        +{static} BatteryHealthPercent(design, full): int
        +{static} BatteryHealthLabel(hasBattery, pct): string
        +{static} DiskFreeLabel(free, total): string
        +{static} UptimeLabel(lastBoot): string
    }

    class FolderUsage {
        +Path: string
        +SizeBytes: long
        +{static} FromHashtable(h): FolderUsage
        +ToHashtable(): Hashtable
    }

    class DiskUsageReport {
        +ScannedAt: string
        +Folders: FolderUsage[]
        +{static} FromHashtable(h): DiskUsageReport
        +ToHashtable(): Hashtable
    }

    class WizTreeCsv {
        +{static} ParseTopFolders(csvText, topN): DiskUsageReport
    }

    class FolderTreeNode {
        +Path: string
        +Label: string
        +SizeBytes: long
        +Depth: int
        +Children: FolderTreeNode[]
    }

    class DiskUsageTree {
        +{static} Build(folders): FolderTreeNode[]
        +{static} BuildNested(folders): FolderTreeNode[]
    }

    class DiskUsageFormat {
        +{static} SizeLabel(bytes): string
    }

    class AdSearchResult {
        +Kind: string
        +Name: string
        +SamAccountName: string
        +UserPrincipalName: string
        +Domain: string
        +Enabled: bool
        +LockedOut: bool
        +Key(): string
        +Label(): string
    }

    class AdFilter {
        +{static} EscapeLdap(text): string
        +{static} UserFilter(prefix): string
        +{static} ComputerFilter(prefix): string
        +{static} IsLockedFromComputed(uacComputed): bool
        +{static} IsDisabledFromUac(uac): bool
    }

    class RecentConnection {
        +Hostname: string
        +LastSeen: string
        +LastStatus: string
        +LastJobType: string
        +UpdateCount: int
        +RebootRequired: bool
        +Inventory: MachineInventory
        +DiskUsage: DiskUsageReport
        +{static} FromHashtable(h): RecentConnection
    }

    class RecentConnectionsStore {
        +{static} Cap: int
        +Upsert(host, status, jobType, count, reboot): void
        +UpsertInventory(host, inv): void
        +UpsertDiskUsage(host, report): void
        +Remove(host): void
        +SeedFrom(hosts): void
        +GetAll(): RecentConnection[]
        +{static} ParseSeen(value): datetime
    }

    enum PollOutcome {
        Authorized
        KeepPolling
        SlowDown
        Failed
    }

    class DeviceFlowDecision {
        +Outcome: PollOutcome
        +TokenData: object
        +Message: string
        +{static} FromPollResult(result): DeviceFlowDecision
    }
}

package "Donut.Core" #102A20 {
    class ConfigManager {
        +SourceRoot: string
        +LoadConfig(): AppConfig
        +SaveConfig(config): void
        +EnsureDirectories(): void
    }

    class NetworkProbe {
        +ResolveHost(hostname): IPAddress
        +CheckReverseDNS(ip, expectedName): bool
        +IsRpcAvailable(hostname): bool
        +IsOnline(hostname): bool
    }

    class AsyncJob {
        +HostName: string
        +JobType: JobKind
        +Status: JobStatus
        +Logs: ConcurrentQueue<string>
        +Result: object
        +Start(scriptPath, arguments, tempConfig): void
        +Poll(): void
        +Cleanup(): void
    }

    class RunspaceManager {
        +{static} Initialize(min, max): void
        +{static} GetPool(): RunspacePool
        +{static} Close(): void
    }

    class HostListSource {
        +SourceRoot: string
        +ReadHosts(): string[]
        +ResolvePath(): string
    }

    class TimeFormat {
        +{static} Relative(when): string
    }
}

package "Donut.Services" #221634 {
    class LogService {
        +LogInfo(message): void
        +LogError(message): void
        +LogWarning(message): void
        +LogException(message, errorRecord): void
        +{static} Coalesce(logger): LogService
    }
    class NullLogService extends LogService

    class RemoteJobService {
        #Config: AppConfig
        #Probe: NetworkProbe
        #Logger: LogService
        +{static} AssertHostReachable(probe, logger, host): string
        #BuildWorkerArgs(host, jobType, options): Hashtable
    }

    class ScanService {
        +PrepareScan(host): Hashtable
    }

    class RemoteUpdateService {
        +DriverMatcher: DriverMatchingService
        +PrepareScanForUpdates(host): Hashtable
        +ParseUpdateReport(host): XmlDocument
        +PrepareApplyUpdates(host, options): Hashtable
        +CountUpdates(report): int
    }

    class HostResolver {
        +Ttl: timespan
        +NeedsResolve(host): bool
        +PrepareResolve(host): Hashtable
        +PrepareWarmRunspace(): Hashtable
        +Record(host, ip, online): void
        +CachedIp(host): string
    }

    class InventoryService {
        +PrepareInventory(host): Hashtable
        +ParseInventory(host): MachineInventory
        +{static} BuildProbeScript(host): string
    }

    class DiskUsageService {
        +{static} TopN: int
        +PrepareDiskScan(host): Hashtable
        +ParseDiskUsage(host): DiskUsageReport
    }

    class ActiveDirectoryService {
        +Domains: string[]
        +Search(prefix): AdSearchResult[]
        +UnlockUser(user): bool
        #QueryDirectory(domain, filter, props, max): Hashtable[]
        #InvokeUnlock(sam, domain): void
    }

    class ExecutionService {
        +{static} StartWorker(host, jobType, options, config, ...): Hashtable
        +RunResolvePhase(device, options): Hashtable
        +RunScanPhase(device): Hashtable
        +RunApplyPhase(device, options): Hashtable
        +RunInventoryPhase(device, options): Hashtable
        +RunDiskScanPhase(device, options): Hashtable
        +CopyRemoteArtifacts(host, ip): Hashtable
    }

    class DriverMatchingService {
        +DetectBrand(manufacturer): string
        +FindBestDriverMatch(updateName, installedDrivers): object
        +CompareVersions(installed, update): Hashtable
        +FormatMatchResult(match, name, version): string
    }

    class SelfUpdateService {
        +GetStoredToken(): string
        +SaveToken(tokenData): void
        +InitiateDeviceFlow(): PSCustomObject
        +PollForToken(deviceCode): PSCustomObject
        +GetLatestRelease(token): PSCustomObject
        +DownloadAsset(token, asset, destDir): string
        +VerifyFileHash(path, expectedHash): bool
        +ApplyUpdate(msiPath, isRollback, sourceRoot): void
    }

    class ResourceService {
        +LoadGlobalResources(): ResourceDictionary
        +ApplyResourcesToWindow(window): void
    }

    class SystemInfo {
        +Hostname: string
        +IPv4: string
        +Domain: string
        +DomainController: string
        +HasBattery: bool
        +BatteryPercent: int
    }

    class SystemInfoService {
        +Gather(): SystemInfo
        +{static} BatteryLabel(hasBattery, percent, charging): string
    }
}

package "Donut.UI.Presenters" #2B1A12 {
    class AsyncJobPresenter {
        #ActiveJobs: List<AsyncJob>
        +PumpJobs(): void
        #OnJobPolled(job): void
        #OnJobCompleted(job): void
        #AfterPump(): void
    }

    class MainPresenter {
        -ConfigManager: ConfigManager
        -HomePresenter: HomePresenter
        -ConfigPresenter: ConfigPresenter
        -LogsPresenter: LogsPresenter
        -Resources: ResourceService
        +Initialize(): void
        +Show(): void
        +NavigateTo(viewName): void
        +ToggleRail(): void
    }

    class HomePresenter extends AsyncJobPresenter {
        -ScanService: ScanService
        -UpdateService: RemoteUpdateService
        -InventoryService: InventoryService
        -DiskUsageService: DiskUsageService
        -Resolver: HostResolver
        -AdService: ActiveDirectoryService
        -Store: RecentConnectionsStore
        -ScanCacheTtl: timespan
        +OnSearch(): void
        +RunAll(): void
        +RunHost(host): void
        +StartProcess(host): void
        +RecentScanIsFresh(host): bool
        +ProceedWithApply(host): bool
        +StartInventory(host, force): void
        +FindBigFolders(host): void
        +RenderBigFolders(report): void
        +RunAdSearch(): void
        +WarmPool(): void
    }

    class ConfigPresenter {
        +LoadCurrentConfig(): void
        +OnCommandChanged(item): void
        +OnSave(): void
    }

    class LogsPresenter {
        +LoadLogs(): void
        +ClearLogs(): void
    }

    class DialogPresenter {
        +ShowConfirmation(title, message, listItems): bool
        +ShowAlert(title, message, listItems): void
        +ShowUpdatePrompt(currentVer, newVer, isRollback): bool
    }

    class LoginPresenter {
        +ShowLogin(): bool
        -StartAuthFlow(): void
        -OnPollTick(): void
    }

    class UpdatePresenter {
        +CheckAndPrompt(): void
        -ShowUpdateWindow(release, localVer, remoteVer): void
    }

    class ConnectionRow {
        +HostName: string
        +RunAction: ScriptBlock
        +SetIdleFrom(rc): void
        +SetStatus(status): void
        +SetPercent(percent): void
        +SetReachability(state): void
        +{static} IdleColorKey(lastStatus): string
    }

    class ToastService {
        +ShowSuccess(title, message): void
        +ShowInfo(title, message): void
        +ShowWarning(title, message): void
        +ShowError(title, message): void
    }
}

