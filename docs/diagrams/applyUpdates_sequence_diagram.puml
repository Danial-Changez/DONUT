@startuml Apply Updates Sequence Diagram
title Apply Updates (scan reuse + confirm)

actor User
participant "HomePresenter" as Presenter
participant "RemoteUpdateService" as Update
participant "DriverMatchingService" as Matcher
participant "DialogPresenter" as Dialog
participant "AsyncJob" as Job
participant "ExecutionService" as Exec

User -> Presenter: Run host (mode = Apply) / Run all
activate Presenter
Presenter -> Presenter: StartProcess("PC-01")

alt Scan < 24h old and report cached
    Presenter -> Presenter: RecentScanIsFresh() = true
    note right of Presenter: Reuse the cached scan —\nskip straight to apply.
else No fresh scan
    Presenter -> Update: PrepareScanForUpdates("PC-01")
    Update --> Presenter: worker args
    Presenter -> Job: queue UpdateScan
    note right of Presenter: PumpJobs() runs the scan,\nthen OnJobCompleted() continues.
end

Presenter -> Presenter: ProceedWithApply("PC-01")
activate Presenter
Presenter -> Update: ParseUpdateReport("PC-01")
activate Update
Update -> Matcher: FindBestDriverMatch(updates, drivers)
Matcher --> Update: matched updates
Update --> Presenter: update list
deactivate Update

alt Updates available
    Presenter -> Dialog: ShowConfirmation("Apply N updates?", list)
    activate Dialog
    Dialog -> User: modal popup
    User --> Dialog: Confirm
    Dialog --> Presenter: true
    deactivate Dialog

    Presenter -> Update: PrepareApplyUpdates("PC-01", selected)
    Update --> Presenter: worker args
    Presenter -> Job: queue UpdateApply
    activate Job
    Job -> Exec: (pool) RunApplyPhase(device, options)
    Exec --> Job: apply result + reboot flag
    deactivate Job
    Presenter -> Presenter: SettleHost() -> updateCount = 0
    opt Reboot required
        Presenter -> Presenter: ManualRebootQueue.Add("PC-01")
    end
else No updates
    Presenter -> User: Toast "No updates found"
end
deactivate Presenter
deactivate Presenter

opt Reboot queue not empty
    Presenter -> User: Show "manual reboot required" notice
end
@enduml
