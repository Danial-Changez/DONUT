@startuml Self-Update Sequence Diagram
title Self-Update (GitHub device flow + MSI)

actor User
participant "Login / UpdatePresenter" as Presenter
participant "SelfUpdateService" as Service
participant "GitHub API" as GH
participant "InstallWorker.ps1" as Worker

Presenter -> Service: GetStoredToken()
activate Service
Service --> Presenter: DPAPI-decrypted token (or null)
deactivate Service

alt No valid token
    Presenter -> Service: InitiateDeviceFlow()
    activate Service
    Service -> GH: POST /login/device/code
    GH --> Service: device_code, user_code, verification_uri
    Service --> Presenter: device-flow response
    deactivate Service

    Presenter -> User: Show user_code + verification_uri\n(copied to clipboard)

    loop until authorized (DeviceFlowDecision)
        Presenter -> Service: PollForToken(deviceCode)
        activate Service
        Service -> GH: POST /login/oauth/access_token
        GH --> Service: access_token (or pending / slow_down)
        Service --> Presenter: token (or keep polling)
        deactivate Service
    end

    Presenter -> Service: SaveToken(tokenData)
    note right of Service: DPAPI (CurrentUser) + ACL hardened
end

Presenter -> Service: GetLatestRelease(token)
activate Service
Service -> GH: GET /repos/.../releases/latest
GH --> Service: release JSON (tag, assets)
Service --> Presenter: release
deactivate Service

Presenter -> Service: GetLocalVersion()
Service --> Presenter: installed version
Presenter -> Presenter: compare versions

alt Update / rollback needed
    Presenter -> User: ShowUpdatePrompt(current, new)
    User --> Presenter: Confirm

    Presenter -> Service: DownloadAsset(token, "*.msi", staging)
    activate Service
    Service -> GH: download MSI (+ checksum)
    GH --> Service: MSI file
    Service --> Presenter: local MSI path
    deactivate Service

    Presenter -> Service: VerifyFileHash(path, expectedHash)
    note right of Service: SHA-256 — abort on mismatch

    Presenter -> Service: ApplyUpdate(msiPath, isRollback, sourceRoot)
    activate Service
    Service -> Worker: Start-Process pwsh InstallWorker.ps1
    activate Worker
    Worker -> Worker: stop DONUT (graceful)
    Worker -> Worker: msiexec /i NewVersion.msi /passive
    Worker -> Worker: relaunch Donut.Launcher.exe
    deactivate Worker
    deactivate Service
    note over Presenter: app restarts on the new version
else Already current
    Presenter -> User: "Already up to date"
end
@enduml
