<?xml version="1.0" encoding="UTF-8"?>
<!-- HomeView.xaml -->
<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <Grid.RowDefinitions>
    <RowDefinition Height="Auto" />
    <!-- Action bar -->
    <RowDefinition Height="Auto" />
    <!-- Overview strip -->
    <RowDefinition Height="*" />
    <!-- Machine list -->
  </Grid.RowDefinitions>

  <!-- ============================ Action bar ============================ -->
  <Grid Grid.Row="0" Margin="0,0,0,16">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>

    <!-- Add / run input (still accepts a pasted batch of WSIDs) -->
    <Border
      x:Name="SearchBox"
      Grid.Column="0"
      Background="{DynamicResource PanelBackground}"
      BorderBrush="{DynamicResource PanelBorder}"
      BorderThickness="1"
      CornerRadius="10"
      Padding="10,0"
      Height="44"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="30" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="130" />
        </Grid.ColumnDefinitions>
        <Path
          Data="{DynamicResource Search}"
          Height="18"
          Width="18"
          Stretch="Uniform"
          Fill="{DynamicResource BodyTextTertiary}"
          VerticalAlignment="Center"
          Grid.Column="0"
        />
        <TextBox
          x:Name="GoogleSearchBar"
          Style="{DynamicResource GoogleSearchBar}"
          Grid.Column="1"
          Margin="4,0"
          AcceptsReturn="True"
          TextWrapping="Wrap"
          VerticalScrollBarVisibility="Auto"
          VerticalContentAlignment="Center"
          FontWeight="SemiBold"
        />
        <Button
          x:Name="btnSearch"
          Grid.Column="2"
          Content="Add"
          Style="{DynamicResource ButtonPrimary}"
          FontSize="12.5"
          Height="32"
          MinWidth="120"
          Margin="6,0,0,0"
          VerticalAlignment="Center"
        />
      </Grid>
    </Border>

    <!-- Live AD finder dropdown: computers (type-ahead for scan/run) + users (UPN, unlock when locked) -->
    <Popup x:Name="SearchResultsPopup"
           Grid.Column="0"
           PlacementTarget="{Binding ElementName=SearchBox}"
           Placement="Bottom"
           AllowsTransparency="True"
           StaysOpen="True"
           PopupAnimation="Fade"
           Width="{Binding ActualWidth, ElementName=SearchBox}">
      <Border Background="{DynamicResource PanelBackground}"
              BorderBrush="{DynamicResource PanelBorder}"
              BorderThickness="1"
              CornerRadius="10"
              Margin="0,4,0,0"
              Padding="6"
              SnapsToDevicePixels="True">
        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="340">
          <StackPanel x:Name="SearchResultsList" />
        </ScrollViewer>
      </Border>
    </Popup>

    <!-- Quick mode cycle: click to switch the active command, using its defaults -->
    <Button
      x:Name="btnMode"
      Grid.Column="1"
      VerticalAlignment="Center"
      Margin="12,0,0,0"
      Style="{DynamicResource GhostButton}"
      ToolTip="Click to cycle the active command (Scan / Apply Updates) using its defaults"
    >
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <TextBlock Text="&#x27F3;" FontFamily="Segoe UI Symbol" FontSize="13"
                   Foreground="{DynamicResource BodyTextTertiary}" VerticalAlignment="Center" Margin="0,0,7,0" />
        <TextBlock x:Name="txtMode" Text="Scan" FontFamily="Montserrat" FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource TitleTextPrimary}" VerticalAlignment="Center" />
      </StackPanel>
    </Button>

    <!-- Run all idle machines using the active mode (Scan / Apply Updates) -->
    <Button
      x:Name="btnRunAll"
      Grid.Column="2"
      Content="Run all"
      Style="{DynamicResource ButtonOutline}"
      Width="100"
      Height="36"
      Margin="12,0,0,0"
    />
  </Grid>

  <!-- ============= Overview strip: mirrors the SELECTED remote machine ============= -->
  <Grid Grid.Row="1" Margin="0,0,0,18">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Machine (model + service tag) -->
    <Border Grid.Column="0" Margin="0,0,6,0" CornerRadius="10" Padding="16,14"
            Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
      <StackPanel>
        <TextBlock Text="MACHINE" FontFamily="Montserrat" FontSize="10.5" FontWeight="SemiBold"
                   Foreground="{DynamicResource BodyTextTertiary}" />
        <TextBlock x:Name="txtOvModel" Text="—" FontFamily="Montserrat" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TitleTextPrimary}" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" />
        <TextBlock x:Name="txtOvModelSub" Text="no machine selected" FontFamily="Montserrat" FontSize="11.5"
                   Foreground="{DynamicResource BodyTextTertiary}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
      </StackPanel>
    </Border>

    <!-- Battery health -->
    <Border Grid.Column="1" Margin="6,0,6,0" CornerRadius="10" Padding="16,14"
            Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
      <StackPanel>
        <TextBlock Text="BATTERY HEALTH" FontFamily="Montserrat" FontSize="10.5" FontWeight="SemiBold"
                   Foreground="{DynamicResource BodyTextTertiary}" />
        <TextBlock x:Name="txtOvBattery" Text="—" FontFamily="Montserrat" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TitleTextPrimary}" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" />
        <TextBlock x:Name="txtOvBatterySub" Text="" FontFamily="Montserrat" FontSize="11.5"
                   Foreground="{DynamicResource BodyTextTertiary}" Margin="0,2,0,0" />
      </StackPanel>
    </Border>

    <!-- Disk free -->
    <Border Grid.Column="2" Margin="6,0,6,0" CornerRadius="10" Padding="16,14"
            Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
      <StackPanel>
        <TextBlock Text="DISK" FontFamily="Montserrat" FontSize="10.5" FontWeight="SemiBold"
                   Foreground="{DynamicResource BodyTextTertiary}" />
        <TextBlock x:Name="txtOvDisk" Text="—" FontFamily="Montserrat" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TitleTextPrimary}" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" />
        <TextBlock x:Name="txtOvDiskSub" Text="" FontFamily="Montserrat" FontSize="11.5"
                   Foreground="{DynamicResource BodyTextTertiary}" Margin="0,2,0,0" />
      </StackPanel>
    </Border>

    <!-- Updates pending -->
    <Border Grid.Column="3" Margin="6,0,0,0" CornerRadius="10" Padding="16,14"
            Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
      <StackPanel>
        <TextBlock Text="UPDATES" FontFamily="Montserrat" FontSize="10.5" FontWeight="SemiBold"
                   Foreground="{DynamicResource BodyTextTertiary}" />
        <TextBlock x:Name="txtOvUpdates" Text="—" FontFamily="Montserrat" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TitleTextPrimary}" Margin="0,6,0,0" />
        <TextBlock x:Name="txtOvUpdatesSub" Text="" FontFamily="Montserrat" FontSize="11.5"
                   Foreground="{DynamicResource BodyTextTertiary}" Margin="0,2,0,0" />
      </StackPanel>
    </Border>
  </Grid>

  <!-- ==================== Machine list (left) + detail pane (right) ==================== -->
  <Grid Grid.Row="2">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="2*" MinWidth="300" />
      <ColumnDefinition Width="6" />
      <ColumnDefinition Width="3*" MinWidth="320" />
    </Grid.ColumnDefinitions>

  <!-- Machine list -->
  <Border Grid.Column="0" CornerRadius="10" Padding="2"
          Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- List header -->
      <Grid Grid.Row="0" Margin="14,12,14,8">
        <TextBlock Text="MACHINES" FontFamily="Montserrat" FontSize="11" FontWeight="SemiBold"
                   Foreground="{DynamicResource BodyTextTertiary}" VerticalAlignment="Center" />
        <Button x:Name="btnClearTabs" Content="Clear completed" Style="{DynamicResource ButtonGhost}"
                FontSize="12.5" Width="150" Height="32" HorizontalAlignment="Right" />
      </Grid>

      <!-- Rows -->
      <ScrollViewer Grid.Row="1" Margin="10,0,10,10" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid>
          <TextBlock
            x:Name="FleetEmptyHint"
            Text="No machines yet. Enter computer names above and run a scan or update."
            Foreground="{DynamicResource BodyTextTertiary}"
            FontFamily="Montserrat"
            FontSize="14"
            TextWrapping="Wrap"
            TextAlignment="Center"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Margin="40"
          />
          <ItemsControl x:Name="MachineList" />
        </Grid>
      </ScrollViewer>
    </Grid>
  </Border>

    <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                  Background="Transparent" ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" />

    <!-- ============================ Detail pane ============================ -->
    <Border x:Name="DetailPane" Grid.Column="2" CornerRadius="10" Padding="2"
            Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
      <Grid Margin="14,12,14,12">
        <!-- Empty state -->
        <TextBlock x:Name="DetailEmptyHint"
                   Text="Select a machine to view its details."
                   Foreground="{DynamicResource BodyTextTertiary}" FontFamily="Montserrat" FontSize="14"
                   TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40" />

        <!-- Content (shown once a machine is selected) -->
        <Grid x:Name="DetailContent" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Folders + log split the remaining height equally, so a window resize
                 grows/shrinks both by the same amount. -->
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <!-- Header: host + actions -->
          <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
              <TextBlock x:Name="txtDetailHost" Text="—" FontFamily="Montserrat" FontSize="18" FontWeight="Bold"
                         Foreground="{DynamicResource TitleTextPrimary}" TextTrimming="CharacterEllipsis" />
              <TextBlock x:Name="txtDetailProbed" Text="" FontFamily="Montserrat" FontSize="11"
                         Foreground="{DynamicResource BodyTextTertiary}" Margin="0,2,0,0" />
            </StackPanel>
            <Button x:Name="btnFindFolders" Grid.Column="1" Content="Storage scan"
                    Style="{DynamicResource ButtonOutline}" FontSize="12.5" Width="124" Height="32" Margin="6,0,0,0" />
            <Button x:Name="btnDetailRefresh" Grid.Column="2" Content="Refresh info"
                    Style="{DynamicResource ButtonOutline}" FontSize="12.5" Width="110" Height="32" Margin="6,0,0,0" />
          </Grid>

          <!-- Largest folders on C: (populated on demand by the "Find big folders" scan) -->
          <Border Grid.Row="1" Margin="0,0,0,12" CornerRadius="10" Padding="14,12"
                  Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <TextBlock Grid.Row="0" Text="LARGEST FOLDERS ON C:" FontFamily="Montserrat" FontSize="10.5" FontWeight="SemiBold"
                         Foreground="{DynamicResource BodyTextTertiary}" Margin="0,0,0,8" />
              <TextBlock Grid.Row="1" x:Name="DiskFoldersHint"
                         Text="Click &quot;Storage scan&quot; to scan this machine's C: drive."
                         Foreground="{DynamicResource BodyTextTertiary}" FontFamily="Montserrat" FontSize="12"
                         TextWrapping="Wrap" />
              <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <TreeView x:Name="DiskFoldersList"
                          Style="{DynamicResource DiskTree}"
                          ItemContainerStyle="{DynamicResource DiskTreeItem}"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
              </ScrollViewer>
            </Grid>
          </Border>

          <!-- Live job log -->
          <Border Grid.Row="2" CornerRadius="8" Background="#0B0B0E" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <ProgressBar x:Name="DetailProgress" Grid.Row="0" Height="3" Minimum="0" Maximum="100"
                           Visibility="Collapsed" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AccentPurple}" />
              <!-- Wrap + no horizontal scrollbar: the themed ScrollBar template is
                   vertical-only, so a horizontal bar renders as a stray white box. -->
              <TextBox x:Name="txtDetailLog" Grid.Row="1" IsReadOnly="True" Background="Transparent" BorderThickness="0"
                       Foreground="#D4D4D8" FontFamily="Consolas" FontSize="12"
                       TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="6" />
            </Grid>
          </Border>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Grid>
