<?xml version="1.0" encoding="UTF-8"?>
<!-- HomeView.xaml -->
<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <Grid.RowDefinitions>
    <RowDefinition Height="Auto" />
    <!-- Action bar -->
    <RowDefinition Height="Auto" />
    <!-- Overview strip -->
    <RowDefinition Height="*" />
    <!-- Machine list -->
  </Grid.RowDefinitions>

  <!-- ============================ Action bar ============================ -->
  <Grid Grid.Row="0" Margin="0,0,0,16">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>

    <!-- Add / run input (still accepts a pasted batch of WSIDs) -->
    <Border
      Grid.Column="0"
      Background="{DynamicResource PanelBackground}"
      BorderBrush="{DynamicResource PanelBorder}"
      BorderThickness="1"
      CornerRadius="10"
      Padding="10,0"
      Height="44"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="30" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="130" />
        </Grid.ColumnDefinitions>
        <Path
          Data="{DynamicResource Search}"
          Height="18"
          Width="18"
          Stretch="Uniform"
          Fill="{DynamicResource BodyTextTertiary}"
          VerticalAlignment="Center"
          Grid.Column="0"
        />
        <TextBox
          x:Name="GoogleSearchBar"
          Style="{DynamicResource GoogleSearchBar}"
          Grid.Column="1"
          Margin="4,0"
          AcceptsReturn="True"
          TextWrapping="Wrap"
          VerticalScrollBarVisibility="Auto"
          VerticalContentAlignment="Center"
          FontWeight="SemiBold"
        />
        <Button
          x:Name="btnSearch"
          Grid.Column="2"
          Content="Scan"
          FontSize="12"
          FontFamily="Montserrat"
          Cursor="Hand"
          BorderThickness="0"
          Foreground="White"
          Height="32"
          MinWidth="120"
          Margin="6,0,0,0"
          VerticalAlignment="Center"
        >
          <Button.Style>
            <Style TargetType="Button">
              <Setter Property="Background" Value="{DynamicResource AccentPurple}" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="Button">
                    <Border Height="32" CornerRadius="8" Background="{TemplateBinding Background}">
                      <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Border>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
              <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="Background" Value="{DynamicResource AccentPurpleHover}" />
                </Trigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
        </Button>
      </Grid>
    </Border>

    <!-- Active mode pill -->
    <Border
      Grid.Column="1"
      VerticalAlignment="Center"
      Margin="12,0,0,0"
      CornerRadius="8"
      Padding="12,6"
      Background="{DynamicResource PanelBackground}"
      BorderBrush="{DynamicResource PanelBorder}"
      BorderThickness="1"
    >
      <TextBlock
        x:Name="txtMode"
        Text="Mode: Scan"
        FontFamily="Montserrat"
        FontSize="12"
        FontWeight="SemiBold"
        Foreground="{DynamicResource AccentPurpleLight}"
      />
    </Border>

    <!-- Refresh -->
    <Button
      x:Name="btnRefresh"
      Grid.Column="2"
      Content="Refresh"
      Style="{DynamicResource ModernButton}"
      Width="100"
      Height="40"
      Margin="12,0,0,0"
    />
  </Grid>

  <!-- ============================ Overview strip ============================ -->
  <Grid Grid.Row="1" Margin="0,0,0,18">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Controller -->
    <Border Grid.Column="0" Margin="0,0,6,0" CornerRadius="10" Padding="16,14"
            Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
      <StackPanel>
        <TextBlock Text="CONTROLLER" FontFamily="Montserrat" FontSize="10.5" FontWeight="SemiBold"
                   Foreground="{DynamicResource BodyTextTertiary}" />
        <TextBlock x:Name="txtCtrlHost" Text="—" FontFamily="Montserrat" FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource TitleTextPrimary}" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" />
        <TextBlock x:Name="txtCtrlIp" Text="" FontFamily="Montserrat" FontSize="11.5"
                   Foreground="{DynamicResource BodyTextTertiary}" Margin="0,2,0,0" />
      </StackPanel>
    </Border>

    <!-- Domain / DC -->
    <Border Grid.Column="1" Margin="6,0,6,0" CornerRadius="10" Padding="16,14"
            Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
      <StackPanel>
        <TextBlock Text="DOMAIN / DC" FontFamily="Montserrat" FontSize="10.5" FontWeight="SemiBold"
                   Foreground="{DynamicResource BodyTextTertiary}" />
        <TextBlock x:Name="txtDc" Text="—" FontFamily="Montserrat" FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource TitleTextPrimary}" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" />
        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
          <Ellipse x:Name="dotDc" Width="8" Height="8" VerticalAlignment="Center"
                   Fill="{DynamicResource BodyTextTertiary}" Margin="0,0,6,0" />
          <TextBlock x:Name="txtDcSub" Text="" FontFamily="Montserrat" FontSize="11.5"
                     Foreground="{DynamicResource BodyTextTertiary}" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Battery -->
    <Border Grid.Column="2" Margin="6,0,6,0" CornerRadius="10" Padding="16,14"
            Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
      <StackPanel>
        <TextBlock Text="BATTERY" FontFamily="Montserrat" FontSize="10.5" FontWeight="SemiBold"
                   Foreground="{DynamicResource BodyTextTertiary}" />
        <TextBlock x:Name="txtBattery" Text="—" FontFamily="Montserrat" FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource TitleTextPrimary}" Margin="0,6,0,0" />
        <TextBlock Text="this machine" FontFamily="Montserrat" FontSize="11.5"
                   Foreground="{DynamicResource BodyTextTertiary}" Margin="0,2,0,0" />
      </StackPanel>
    </Border>

    <!-- Fleet -->
    <Border Grid.Column="3" Margin="6,0,0,0" CornerRadius="10" Padding="16,14"
            Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
      <StackPanel>
        <TextBlock Text="FLEET" FontFamily="Montserrat" FontSize="10.5" FontWeight="SemiBold"
                   Foreground="{DynamicResource BodyTextTertiary}" />
        <TextBlock x:Name="txtFleet" Text="0" FontFamily="Montserrat" FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource TitleTextPrimary}" Margin="0,6,0,0" />
        <TextBlock x:Name="txtFleetSub" Text="0 active" FontFamily="Montserrat" FontSize="11.5"
                   Foreground="{DynamicResource BodyTextTertiary}" Margin="0,2,0,0" />
      </StackPanel>
    </Border>
  </Grid>

  <!-- ============================ Machine list ============================ -->
  <Border Grid.Row="2" CornerRadius="10" Padding="2"
          Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- List header -->
      <Grid Grid.Row="0" Margin="14,12,14,8">
        <TextBlock Text="MACHINES" FontFamily="Montserrat" FontSize="11" FontWeight="SemiBold"
                   Foreground="{DynamicResource BodyTextTertiary}" VerticalAlignment="Center" />
        <Button x:Name="btnClearTabs" Content="Clear completed" Style="{DynamicResource ModernButton}"
                Width="150" Height="32" HorizontalAlignment="Right" />
      </Grid>

      <!-- Rows -->
      <ScrollViewer Grid.Row="1" Margin="10,0,10,10" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid>
          <TextBlock
            x:Name="FleetEmptyHint"
            Text="No machines yet. Enter computer names above and run a scan or update."
            Foreground="{DynamicResource BodyTextTertiary}"
            FontFamily="Montserrat"
            FontSize="14"
            TextWrapping="Wrap"
            TextAlignment="Center"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Margin="40"
          />
          <ItemsControl x:Name="MachineList" />
        </Grid>
      </ScrollViewer>
    </Grid>
  </Border>
</Grid>
