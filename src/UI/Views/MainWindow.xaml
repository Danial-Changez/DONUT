<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        Title="DONUT"
        Height="700"
        Width="1300"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="{DynamicResource PrimaryBackground}"
        AllowsTransparency="False"
        ResizeMode="CanResize">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Grid>
        <!-- Main window border and content -->
        <Border CornerRadius="10"
                BorderThickness="1"
                Background="Transparent"
                x:Name="rootBorder">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="1,1">
                    <GradientStop Color="{DynamicResource WindowBorderPrimaryColor}"
                                  Offset="0" />
                    <GradientStop Color="{DynamicResource WindowBorderAccentColor}"
                                  Offset="0" />
                    <GradientStop Color="{DynamicResource WindowBorderSecondaryColor}"
                                  Offset="0" />
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Sidebar (Auto so it follows the animated rail width) -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Main Section -->
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <!-- Sidebar -->
                <Border x:Name="sidebar"
                        CornerRadius="10,0,0,10"
                        Width="250"
                        ClipToBounds="True"
                        Grid.Column="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="1,0.75"
                                             EndPoint="0,0">
                            <GradientStop Color="{DynamicResource SecondaryBackgroundDarkColor}"
                                          Offset="0" />
                            <GradientStop Color="{DynamicResource SecondaryBackgroundColor}"
                                          Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <StackPanel x:Name="SidebarPanel"
                                    Background="Transparent"
                                    HorizontalAlignment="Stretch"
                                    Margin="10,0,0,0">
                            <!-- The logo IS the collapse/expand toggle: full DONUT wordmark when
                                 expanded, donut icon when collapsed (the image source is swapped
                                 in MainPresenter.ToggleRail). Top margin (30) lines it up with the
                                 page header icon, which sits below the 30px window-control row. -->
                            <Button x:Name="btnRailToggle"
                                    HorizontalAlignment="Left"
                                    Margin="14,24,8,26"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Collapse / expand sidebar">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="6,4">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource PanelBackgroundHover}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Image x:Name="Logo"
                                       Height="44"
                                       Stretch="Uniform"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left" />
                            </Button>
                            <!-- Menu Buttons -->
                            <RadioButton x:Name="btnHome"
                                         Style="{DynamicResource menuButton}"
                                         Tag="{DynamicResource AccentPurpleLight}">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Left">
                                    <Path Style="{DynamicResource menuButtonIcon}"
                                          Data="{DynamicResource Home}" />
                                    <TextBlock x:Name="lblHome"
                                               Text="Home"
                                               Style="{DynamicResource menuButtonText}" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="btnConfig"
                                         Style="{DynamicResource menuButton}"
                                         Tag="{DynamicResource AccentBlue}">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Left">
                                    <Path Style="{DynamicResource menuButtonIcon}"
                                          Data="{DynamicResource Config}" />
                                    <TextBlock x:Name="lblConfig"
                                               Text="Config"
                                               Style="{DynamicResource menuButtonText}" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="btnLogs"
                                         Style="{DynamicResource menuButton}"
                                         Tag="{DynamicResource AccentCyan}">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Left">
                                    <Path Style="{DynamicResource menuButtonIcon}"
                                          Data="{DynamicResource Logs}" />
                                    <TextBlock x:Name="lblLogs"
                                               Text="Logs"
                                               Style="{DynamicResource menuButtonText}" />
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </Grid>
                </Border>
                <!-- Main Section -->
                <Border CornerRadius="0,10,10,0"
                        Grid.Column="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,0.75">
                            <GradientStop Color="{DynamicResource PrimaryBackgroundDarkColor}"
                                          Offset="0" />
                            <GradientStop Color="{DynamicResource PrimaryBackgroundColor}"
                                          Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- Control Bar -->
                            <RowDefinition Height="30" />
                            <!-- Header/Caption -->
                            <RowDefinition Height="40" />
                            <!-- Content Section / Child Views -->
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <!-- Control Bar -->
                        <StackPanel x:Name="panelControlBar"
                                    Grid.Row="0"
                                    Orientation="Horizontal"
                                    FlowDirection="RightToLeft"
                                    Background="Transparent"
                                    Margin="0,0,5,0">
                            <Button x:Name="btnClose"
                                    Style="{DynamicResource controlButton}"
                                    Tag="{DynamicResource AccentPink}">
                                <Path Style="{DynamicResource controlButtonIcon}"
                                      Data="{DynamicResource xMark}" />
                            </Button>
                            <Button x:Name="btnMaximize"
                                    Style="{DynamicResource controlButton}"
                                    Tag="{DynamicResource AccentYellow}">
                                <Path Style="{DynamicResource controlButtonIcon}"
                                      Data="{DynamicResource Square}" />
                            </Button>
                            <Button x:Name="btnMinimize"
                                    Style="{DynamicResource controlButton}"
                                    Tag="{DynamicResource AccentBlueLight}">
                                <Path Style="{DynamicResource controlButtonIcon}"
                                      Width="13"
                                      Data="{DynamicResource Minimize}" />
                            </Button>
                        </StackPanel>
                        <!-- Header -->
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Grid.Row="1">
                            <!-- Home Header -->
                            <StackPanel Orientation="Horizontal"
                                        x:Name="headerHome"
                                        Visibility="Collapsed">
                                <Path Data="{DynamicResource Home}"
                                      Height="24"
                                      Width="24"
                                      Stretch="Uniform"
                                      Fill="{DynamicResource TitleTextSecondary}"
                                      Margin="35,0,10,0" />
                                <TextBlock Text="Home"
                                           Foreground="{DynamicResource TitleTextSecondary}"
                                           FontSize="20"
                                           FontFamily="Montserrat"
                                           FontWeight="Medium"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <!-- Config Header -->
                            <StackPanel Orientation="Horizontal"
                                        x:Name="headerConfig"
                                        Visibility="Collapsed">
                                <Path Data="{DynamicResource Config}"
                                      Height="24"
                                      Width="24"
                                      Stretch="Uniform"
                                      Fill="{DynamicResource TitleTextSecondary}"
                                      Margin="35,0,10,0" />
                                <TextBlock Text="Configuration"
                                           Foreground="{DynamicResource TitleTextSecondary}"
                                           FontSize="20"
                                           FontFamily="Montserrat"
                                           FontWeight="Medium"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <!-- Logs Header -->
                            <StackPanel Orientation="Horizontal"
                                        x:Name="headerLogs"
                                        Visibility="Collapsed">
                                <Path Data="{DynamicResource Logs}"
                                      Height="24"
                                      Width="24"
                                      Stretch="Uniform"
                                      Fill="{DynamicResource TitleTextSecondary}"
                                      Margin="35,0,10,0" />
                                <TextBlock Text="Logs"
                                           Foreground="{DynamicResource TitleTextSecondary}"
                                           FontSize="20"
                                           FontFamily="Montserrat"
                                           FontWeight="Medium"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                        <ContentControl x:Name="contentMain"
                                        Grid.Row="2"
                                        Margin="25" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
        <!-- Toast overlay: non-modal notifications stack here, top-right, above
             everything else. The host itself is click-through; only the toast
             cards inside it are hit-testable. -->
        <ItemsControl x:Name="toastHost"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,44,18,0"
                      Width="340"
                      Background="Transparent"
                      IsHitTestVisible="True" />
    </Grid>
</Window>