<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Palette: Arcane-style zinc + violet (shadcn-like dark theme).
         Near-black zinc backgrounds, zinc-900 cards, violet primary accent,
         status colours kept for green/red/amber/sky. -->
    <!-- Primary/Secondary Background Colors -->
    <Color x:Key="PrimaryBackgroundDarkColor"> #09090B</Color>
    <SolidColorBrush x:Key="PrimaryBackgroundDark"
                     Color="{StaticResource PrimaryBackgroundDarkColor}" />
    <Color x:Key="PrimaryBackgroundColor"> #121214</Color>
    <SolidColorBrush x:Key="PrimaryBackground"
                     Color="{StaticResource PrimaryBackgroundColor}" />
    <Color x:Key="SecondaryBackgroundDarkColor"> #0E0E11</Color>
    <SolidColorBrush x:Key="SecondaryBackgroundDark"
                     Color="{StaticResource SecondaryBackgroundDarkColor}" />
    <Color x:Key="SecondaryBackgroundColor"> #0B0B0E</Color>
    <SolidColorBrush x:Key="SecondaryBackground"
                     Color="{StaticResource SecondaryBackgroundColor}" />
    <Color x:Key="LoginBackgroundDarkColor"> #09090B</Color>
    <SolidColorBrush x:Key="LoginBackgroundDark"
                     Color="{StaticResource LoginBackgroundDarkColor}" />
    <Color x:Key="LoginBackgroundColor"> #121214</Color>
    <SolidColorBrush x:Key="LoginBackground"
                     Color="{StaticResource LoginBackgroundColor}" />
    <!-- Window Border Colors (subtle violet -> zinc gradient) -->
    <Color x:Key="WindowBorderPrimaryColor"> #8B5CF6</Color>
    <SolidColorBrush x:Key="WindowBorderPrimary"
                     Color="{StaticResource WindowBorderPrimaryColor}" />
    <Color x:Key="WindowBorderAccentColor"> #7C3AED</Color>
    <SolidColorBrush x:Key="WindowBorderAccent"
                     Color="{StaticResource WindowBorderAccentColor}" />
    <Color x:Key="WindowBorderSecondaryColor"> #3F3F46</Color>
    <SolidColorBrush x:Key="WindowBorderSecondary"
                     Color="{StaticResource WindowBorderSecondaryColor}" />
    <!-- Login Window Border Colors -->
    <Color x:Key="LoginWindowBorderPrimaryColor"> #7C3AED</Color>
    <SolidColorBrush x:Key="LoginWindowBorderPrimary"
                     Color="{StaticResource LoginWindowBorderPrimaryColor}" />
    <Color x:Key="LoginWindowBorderAccentColor"> #8B5CF6</Color>
    <SolidColorBrush x:Key="LoginWindowBorderAccent"
                     Color="{StaticResource LoginWindowBorderAccentColor}" />
    <Color x:Key="LoginWindowBorderSecondaryColor"> #3F3F46</Color>
    <SolidColorBrush x:Key="LoginWindowBorderSecondary"
                     Color="{StaticResource LoginWindowBorderSecondaryColor}" />
    <!-- Button/Accent Colors -->
    <Color x:Key="AccentPurpleColor"> #8B5CF6</Color>
    <SolidColorBrush x:Key="AccentPurple"
                     Color="{StaticResource AccentPurpleColor}" />
    <Color x:Key="AccentPurpleHoverColor"> #A78BFA</Color>
    <SolidColorBrush x:Key="AccentPurpleHover"
                     Color="{StaticResource AccentPurpleHoverColor}" />
    <Color x:Key="AccentPinkColor"> #F472B6</Color>
    <SolidColorBrush x:Key="AccentPink"
                     Color="{StaticResource AccentPinkColor}" />
    <Color x:Key="AccentBlueColor"> #60A5FA</Color>
    <SolidColorBrush x:Key="AccentBlue"
                     Color="{StaticResource AccentBlueColor}" />
    <Color x:Key="AccentYellowColor"> #FBBF24</Color>
    <SolidColorBrush x:Key="AccentYellow"
                     Color="{StaticResource AccentYellowColor}" />
    <Color x:Key="AccentCyanColor"> #38BDF8</Color>
    <SolidColorBrush x:Key="AccentCyan"
                     Color="{StaticResource AccentCyanColor}" />
    <Color x:Key="AccentGreenColor"> #22C55E</Color>
    <SolidColorBrush x:Key="AccentGreen"
                     Color="{StaticResource AccentGreenColor}" />
    <Color x:Key="AccentRedColor"> #EF4444</Color>
    <SolidColorBrush x:Key="AccentRed"
                     Color="{StaticResource AccentRedColor}" />
    <Color x:Key="AccentBlueLightColor"> #93C5FD</Color>
    <SolidColorBrush x:Key="AccentBlueLight"
                     Color="{StaticResource AccentBlueLightColor}" />
    <Color x:Key="AccentPinkLightColor"> #F9A8D4</Color>
    <SolidColorBrush x:Key="AccentPinkLight"
                     Color="{StaticResource AccentPinkLightColor}" />
    <Color x:Key="AccentPurpleLightColor"> #C4B5FD</Color>
    <SolidColorBrush x:Key="AccentPurpleLight"
                     Color="{StaticResource AccentPurpleLightColor}" />
    <!-- Font Colors (zinc) -->
    <Color x:Key="TitleTextPrimaryColor"> #FAFAFA</Color>
    <SolidColorBrush x:Key="TitleTextPrimary"
                     Color="{StaticResource TitleTextPrimaryColor}" />
    <Color x:Key="TitleTextSecondaryColor"> #E4E4E7</Color>
    <SolidColorBrush x:Key="TitleTextSecondary"
                     Color="{StaticResource TitleTextSecondaryColor}" />
    <Color x:Key="TitleTextTertiaryColor"> #A1A1AA</Color>
    <SolidColorBrush x:Key="TitleTextTertiary"
                     Color="{StaticResource TitleTextTertiaryColor}" />
    <Color x:Key="BodyTextPrimaryColor"> #A1A1AA</Color>
    <SolidColorBrush x:Key="BodyTextPrimary"
                     Color="{StaticResource BodyTextPrimaryColor}" />
    <Color x:Key="BodyTextSecondaryColor"> #71717A</Color>
    <SolidColorBrush x:Key="BodyTextSecondary"
                     Color="{StaticResource BodyTextSecondaryColor}" />
    <Color x:Key="BodyTextTertiaryColor"> #52525B</Color>
    <SolidColorBrush x:Key="BodyTextTertiary"
                     Color="{StaticResource BodyTextTertiaryColor}" />
    <Color x:Key="TerminalTextColor"> #D4D4D8</Color>
    <SolidColorBrush x:Key="TerminalText"
                     Color="{StaticResource TerminalTextColor}" />
    <!-- Panel Colors (zinc cards) -->
    <Color x:Key="PanelBackgroundColor"> #18181B</Color>
    <SolidColorBrush x:Key="PanelBackground"
                     Color="{StaticResource PanelBackgroundColor}" />
    <Color x:Key="PanelBackgroundHoverColor"> #232327</Color>
    <SolidColorBrush x:Key="PanelBackgroundHover"
                     Color="{StaticResource PanelBackgroundHoverColor}" />
    <Color x:Key="PanelBackgroundActiveColor"> #27272A</Color>
    <SolidColorBrush x:Key="PanelBackgroundActive"
                     Color="{StaticResource PanelBackgroundActiveColor}" />
    <Color x:Key="PanelBorderColor"> #27272A</Color>
    <SolidColorBrush x:Key="PanelBorder"
                     Color="{StaticResource PanelBorderColor}" />
    <!-- Misc Colors -->
    <Color x:Key="LoginBoxColor"> #33000000</Color>
    <SolidColorBrush x:Key="LoginBox"
                     Color="{StaticResource LoginBoxColor}" />
    <Color x:Key="GroupBoxBackgroundColor"> #14FFFFFF</Color>
    <SolidColorBrush x:Key="GroupBoxBackground"
                     Color="{StaticResource GroupBoxBackgroundColor}" />
    <Color x:Key="ThrottleLimitColor"> #EF4444</Color>
    <SolidColorBrush x:Key="ThrottleLimit"
                     Color="{StaticResource ThrottleLimitColor}" />
</ResourceDictionary>
